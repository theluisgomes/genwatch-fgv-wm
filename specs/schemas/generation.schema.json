{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GenerationSpec",
  "type": "object",
  "required": ["generations"],
  "properties": {
    "generations": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "label", "theme", "color"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "theme": { "type": "string" },
          "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
        }
      }
    }
  }
}
