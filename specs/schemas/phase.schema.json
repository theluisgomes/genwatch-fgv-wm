{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PhaseSpec",
  "type": "object",
  "required": ["phase", "acceptance_criteria"],
  "properties": {
    "phase": {
      "type": "object",
      "required": ["id", "name", "weeks", "gate"],
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" },
        "weeks": { "type": "array", "items": { "type": "integer" } },
        "gate": { "type": "string" }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  }
}
