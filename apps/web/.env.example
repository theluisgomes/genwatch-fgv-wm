# Direct API URL (optional — bypasses the Vercel proxy route)
# NEXT_PUBLIC_API_URL=https://genwatch-api.onrender.com

# Backend URL for the Vercel proxy at /api/v1/* (recommended for production)
API_PROXY_URL=https://genwatch-api.onrender.com

# Must match the API's GENWATCH_ADMIN_KEY for /admin and protected routes
GENWATCH_ADMIN_KEY=change-me-in-production
